# ============================================================
# Critter backend — environment variables
# Copy to .env and fill in values for local development.
# In production, all of these come from GCP Secret Manager.
# ============================================================

# Django
SECRET_KEY=change-me-to-a-long-random-string
PROD_DEPLOY=False
SITE_URL=http://localhost:5173
REACT_BASE_URL=http://localhost:5173

# Set REQUIRE_2FA=False to skip the email-code step at login (dev convenience).
# Always leave this True (or unset) in production.
REQUIRE_2FA=False

# When True, jobs (auto-describe, video gen, scan) run in a background thread
# inside the Django process — no RQ worker, no Redis dependency. Flip to False
# in prod once you've provisioned Memorystore Redis and want a real worker fleet.
RUN_JOBS_INLINE=True

# Database (local Postgres OR Cloud SQL proxy on port 5433)
GCP_SQL_DB_NAME=critter
GCP_SQL_PROD_USER=postgres
GCP_SQL_PROD_PASSWORD=postgres
GCP_SQL_PUBLIC_IP_ADDRESS=127.0.0.1
GCP_SQL_PORT=5432
GCP_SQL_CONNECTION_NAME=wtroy-test-proj:us-central1:critter-sql

# Redis (local install OR Memorystore via VPC connector in prod)
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=wtroy-test-proj
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_GEMINI_LOCATION=us-central1
GOOGLE_SA_KEYFILE=/path/to/service-account.json
GS_BUCKET_NAME=critter-clean
GS_UNSCANNED_BUCKET_NAME=critter-unscanned
GS_QUARANTINE_BUCKET_NAME=critter-quarantine

# AI provider keys (Veo + Gemini all use the service account, no key needed)
# ANTHROPIC_API_KEY only required if any TEXT_*_MODEL below is claude_sonnet
ANTHROPIC_API_KEY=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=
# Kling uses an Access Key + Secret Key pair (HS256 JWT auth)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Which LLM runs each text-generation task. Defaults are Gemini Flash
# (cheap, uses the service account). Flip a task to 'claude_sonnet' to use
# Claude for that task — requires ANTHROPIC_API_KEY.
TEXT_POLISH_MODEL=gemini_flash
TEXT_CAPTION_MODEL=gemini_flash
TEXT_PLANNER_MODEL=gemini_flash
TEXT_DESCRIBE_MODEL=gemini_flash

# Email (SMTP via Gmail in dev, SendGrid in prod)
EMAIL_HOST_USER=no-reply@critter.app
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Critter <no-reply@critter.app>

# Stripe (Phase 5)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ClamAV (optional in dev, required in prod)
CLAMAV_SCANNER_URL=
ENABLE_CLAMAV_SCANNING=false
